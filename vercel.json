{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "1142labs",
  "public": true,
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" },
        { "key": "Content-Type", "value": "image/x-icon" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/images/(.*)",
      "headers": [ { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" } ]
    },
    {
      "source": "/assets/fonts/(.*)",
      "headers": [ { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" } ]
    },
    {
      "source": "/assets/(.*)\\.css",
      "headers": [ { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" } ]
    },
    {
      "source": "/assets/(.*)\\.js",
      "headers": [ { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" } ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [ { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" } ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/calculators", "destination": "/calculators.html" },
    { "source": "/research-breakthroughs", "destination": "/research_breakthroughs.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/archive", "destination": "/archive.html" },
    { "source": "/creators", "destination": "/creators.html" },
    { "source": "/vision", "destination": "/vision.html" },
    { "source": "/resources", "destination": "/resources.html" },
    { "source": "/posters", "destination": "/posters.html" },
    { "source": "/chemlog", "destination": "/chemlog.html" },
    { "source": "/chemicals", "destination": "/1142_chemicals.html" },
    { "source": "/socials", "destination": "/socials.html" },
    { "source": "/network", "destination": "/socials.html" },
    { "source": "/toke-times", "destination": "/toke_times.html" }
  ],
  "redirects": [
    { "source": "/tools", "destination": "/calculators", "permanent": true },
    { "source": "/withdrawal", "destination": "/calculators", "permanent": true },
    { "source": "/research", "destination": "/research-breakthroughs", "permanent": true },
    { "source": "/breakthroughs", "destination": "/research-breakthroughs", "permanent": true },
    { "source": "/pdf-portal", "destination": "/research-breakthroughs", "permanent": true },
    { "source": "/library", "destination": "/research-breakthroughs", "permanent": true }
  ]
}
