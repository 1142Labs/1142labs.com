{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "name": "1142labs",
  "public": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/research", "destination": "/research.html" },
    { "source": "/tools", "destination": "/tools.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/archive", "destination": "/archive.html" },
    { "source": "/breakthroughs", "destination": "/breakthroughs.html" },
    { "source": "/creators", "destination": "/creators.html" },
    { "source": "/vision", "destination": "/vision.html" },
    { "source": "/resources", "destination": "/resources.html" },
    { "source": "/posters", "destination": "/posters.html" },
    { "source": "/chemlog", "destination": "/chemlog.html" },
    { "source": "/chemicals", "destination": "/1142_chemicals.html" },
    { "source": "/pdf-portal", "destination": "/pdf_portal.html" },
    { "source": "/socials", "destination": "/socials.html" },
    { "source": "/network", "destination": "/socials.html" },
    { "source": "/withdrawal", "destination": "/withdrawal.html" },
    { "source": "/withdrawal-calculator", "destination": "/withdrawal.html" }
  ]
}
